{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "world-cup-command-center",
  "main": "worker/index.ts",
  "compatibility_date": "2026-06-15",
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/sitemap.xml", "/robots.txt", "/llms.txt", "/feed.xml"]
  },
  "triggers": {
    "crons": ["*/15 * * * *", "0 11 * * *"]
  },
  "observability": {
    "enabled": true
  }
}
