{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "world-cup-command-center",
  "main": "worker/index.ts",
  "compatibility_date": "2026-06-15",
  "assets": {
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*", "/sitemap.xml", "/robots.txt", "/llms.txt", "/feed.xml",
      "/matches/*", "/what-changed/*", "/upsets", "/power-rankings",
      "/rankings", "/content/*", "/groups/*", "/teams/*",
      "/bracket", "/compare", "/predictions", "/insights", "/news"
    ]
  },
  "kv_namespaces": [
    {
      "binding": "GOAL_HISTORY",
      "id": "31ceed678f984d8d9d0ca997270c2e71",
      "preview_id": "d57b3009858c4ec9af78b6561cdab4cb"
    }
  ],
  "d1_databases": [
    {
      "binding": "ANALYTICS",
      "database_name": "touchline26-analytics",
      "database_id": "f5b4fd68-c927-415f-a6c1-25f0b0b21629"
    }
  ],
  "triggers": {
    "crons": ["*/15 * * * *", "0 11 * * *"]
  },
  "observability": {
    "enabled": true
  }
}
